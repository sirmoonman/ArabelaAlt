# Copy this file to .env and fill in your values.
# For Gmail, use an App Password (not your normal Gmail password).

# PostgreSQL (Supabase): Project Settings → Database.
# If db.<ref>.supabase.co fails (IPv6-only), use the pooler "Session mode" URI:
# host aws-*-*.pooler.supabase.com, port 5432, user postgres.<project_ref>.
# Transaction pooler (6543) often misbehaves with Django migration checks.
DATABASE_NAME=postgres
DATABASE_USER=postgres.your_project_ref
DATABASE_PASSWORD=your_database_password
DATABASE_HOST=aws-0-your-region.pooler.supabase.com
DATABASE_PORT=5432

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=yourgmail@gmail.com
EMAIL_HOST_PASSWORD=your_16_char_gmail_app_password
DEFAULT_FROM_EMAIL=Arabela <yourgmail@gmail.com>
